{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "grep *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "ls *": "allow"
    },
    "edit": "ask",
    "webfetch": "ask"
  }
}
